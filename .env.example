# ─────────────────────────────────────────────────────────────
# 로컬 개발용 환경변수 (.env로 복사해 사용). .env는 절대 커밋하지 않는다.
# 배포(Railway/Vercel)에서는 아래 값을 플랫폼 환경변수로 주입한다.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (로컬: docker-compose가 이 값으로 컨테이너를 띄움) ──
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=change_me_before_use

# 배포(Railway)에서만 사용 — Railway Postgres가 자동 제공하는 변수.
# 로컬에서는 비워둔다(설정 시 위 POSTGRES_* 대신 이 값이 우선 적용됨).
# 우선순위: PGUSER/PGPASSWORD > POSTGRES_USER/POSTGRES_PASSWORD
#PGHOST=
#PGPORT=5432
#PGDATABASE=studychatbot
#PGUSER=
#PGPASSWORD=

# ── Redis ────────────────────────────────────────────────────
# 로컬: 기본값(localhost:6379, 비밀번호 없음) 사용 — 보통 설정 불필요.
# 배포: 관리형 Redis(Stack) 접속 정보로 주입. 관리형 Redis는 비밀번호 필수.
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_PASSWORD=

# ── CORS 허용 origin (쉼표로 다중 지정 가능) ──────────────────
# 로컬: 미설정 시 http://localhost:5173 기본 허용.
# 배포: Vercel 프론트 도메인을 넣는다. 예) https://your-app.vercel.app
#APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── 서버 포트 ─────────────────────────────────────────────────
# 로컬: 미설정 시 8080. 배포(Railway): 플랫폼이 PORT를 자동 주입하므로 건드리지 않는다.
#PORT=8080

# ── JWT — 토큰 서명용 시크릿. 충분히 긴 무작위 문자열로 직접 생성해 사용한다. ──
JWT_SECRET=your-jwt-secret-here

# ── Gemini — 채팅·임베딩 공용 API 키. Google AI Studio에서 발급. ──
GEMINI_API_KEY=your-gemini-api-key-here
